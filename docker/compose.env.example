# Copy to project root as `.env` — Docker Compose loads it for ${VAR} substitution in docker-compose.yml.
# Local `uv run` also reads `.env` via pydantic-settings (app/core/config.py).

# Required for planner, agents, and LLM-backed tools
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_TRACING_ENVIRONMENT=

# Optional inline judge after agent invoke (tenant migration 008 must be applied)
INLINE_EVAL_ENABLED=false
INLINE_EVAL_MAX_RETRIES=2
INLINE_EVAL_THRESHOLD=0.5
INLINE_EVAL_METRIC_NAME=GoalAdequacy

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

INGESTION_MAX_DEPTH_CAP=2
INGESTION_MAX_LINKS_PER_SOURCE=100
SCRAPER_HTTP_TIMEOUT_SECONDS=600

# Browser / client-side fetches (must be reachable from the user’s machine).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Server Components (RSC) only: base URL for apiGet()/apiPost() from the Next.js server process.
# Local dev on the host: omit or use http://127.0.0.1:8000
# Next.js in Docker: set in compose to http://control-plane:8000 (see docker-compose.yml web service).
# API_URL=http://127.0.0.1:8000

# Copy to .env and fill in your values

# Postgres (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aiworks

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Service ports
CONTROL_PLANE_PORT=8000
CONTENT_INGESTION_AGENT_PORT=8001
SCRAPER_MCP_PORT=8002

# Agent endpoints (used by Execution Engine to call agents)
CONTENT_INGESTION_AGENT_URL=http://localhost:8001
SCRAPER_MCP_URL=http://localhost:8002

LOG_LEVEL=INFO

# Langfuse (optional — leave empty to disable LLM tracing)
# https://langfuse.com/docs
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_TRACING_ENVIRONMENT=development
